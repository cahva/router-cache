{
  "name": "@cahva/router-cache",
  "version": "0.2.1",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./stores/redis": "./src/stores/redis.ts",
    "./stores/memory": "./src/stores/memory.ts",
    "./adapters/hono": "./src/adapters/hono.ts"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "mod.ts",
      "src/**/*.ts"
    ],
    "exclude": [
      "tests/",
      "**/*_test.ts"
    ]
  },
  "tasks": {
    "test": "deno test --allow-net --allow-read",
    "check": "deno check mod.ts src/stores/redis.ts src/stores/memory.ts src/adapters/hono.ts"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4.12.3",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/expect": "jsr:@std/expect@^1",
    "@std/testing": "jsr:@std/testing@^1"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
